{
  "license": "GPL-3.0",
  "repository": "github:AprilSylph/XKit-Rewritten",
  "type": "module",
  "scripts": {
    "test": "web-ext lint",
    "posttest": "eslint src/ --cache",
    "autofix": "eslint src/ --fix",
    "start": "web-ext run",
    "build": "web-ext build",
    "enable-hooks": "git config core.hooksPath .git-hooks",
    "disable-hooks": "git config --unset core.hooksPath"
  },
  "devDependencies": {
    "chrome-webstore-upload-cli": "^4.0.1",
    "eslint": "^10.6.0",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsdoc": "^63.0.10",
    "neostandard": "^0.13.0",
    "web-ext": "^10.4.0"
  },
  "dependencies": {
    "@melloware/coloris": "^0.25.0",
    "jquery": "^4.0.0",
    "modern-normalize": "^3.0.1",
    "moment": "^2.30.1",
    "remixicon": "^4.9.1",
    "sortablejs": "^1.15.7"
  },
  "allowScripts": {
    "unrs-resolver": false
  },
  "webExt": {
    "sourceDir": "src/",
    "build": {
      "overwriteDest": true
    }
  }
}
